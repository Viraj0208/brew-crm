# ── Database (Neon — use the POOLED connection string) ──
DATABASE_URL=

# ── Service discovery ──
CHANNEL_URL=
CRM_PUBLIC_URL=

# ── Worker / receipts shared secret ──
# WORKER_SECRET guards /api/internal/worker and the channel /send.
# On Vercel ALSO set CRON_SECRET to the SAME value — Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`, which the worker route checks.
WORKER_SECRET=
CRON_SECRET=

# ── Runtime LLM (LOCKED: Gemini free default, Groq free fallback) ──
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_FALLBACK=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOOL_CALLS=8
